<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0"
             xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
                                 https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">

    <persistence-unit name="DaNangTravelHubPU" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Entity Classes -->
        <class>com.dananghub.entity.Role</class>
        <class>com.dananghub.entity.User</class>
        <class>com.dananghub.entity.Provider</class>
        <class>com.dananghub.entity.ProviderPriceHistory</class>
        <class>com.dananghub.entity.ProviderRegistration</class>
        <class>com.dananghub.entity.Category</class>
        <class>com.dananghub.entity.Tour</class>
        <class>com.dananghub.entity.TourImage</class>
        <class>com.dananghub.entity.Customer</class>
        <class>com.dananghub.entity.Order</class>
        <class>com.dananghub.entity.Booking</class>
        <class>com.dananghub.entity.Payment</class>
        <class>com.dananghub.entity.MonthlyRevenue</class>
        <class>com.dananghub.entity.SubscriptionPlan</class>
        <class>com.dananghub.entity.ProviderSubscription</class>
        <class>com.dananghub.entity.PaymentTransaction</class>
        <class>com.dananghub.entity.SepayTransaction</class>
        <class>com.dananghub.entity.CustomerActivity</class>
        <class>com.dananghub.entity.InteractionHistory</class>
        <class>com.dananghub.entity.AILog</class>
        <class>com.dananghub.entity.TourSchedule</class>
        <class>com.dananghub.entity.TourPriceSeason</class>
        <class>com.dananghub.entity.Coupon</class>

        <properties>
            <!-- Supabase PostgreSQL Connection (Session Pooler) -->
            <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres?sslmode=require&amp;prepareThreshold=0"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres.cbbdijhwewpptvmgujcz"/>
            <property name="jakarta.persistence.jdbc.password" value="dK6W6dygBt2%uTw"/>

            <!-- Hibernate Settings -->
            <property name="hibernate.dialect"       value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto"  value="none"/>
            <property name="hibernate.show_sql"       value="true"/>
            <property name="hibernate.format_sql"     value="true"/>
            <property name="hibernate.globally_quoted_identifiers" value="true"/>

            <!-- Connection Pool (C3P0) -->
            <property name="hibernate.c3p0.min_size" value="1"/>
            <property name="hibernate.c3p0.max_size" value="5"/>
            <property name="hibernate.c3p0.timeout" value="180"/>
            <property name="hibernate.c3p0.max_statements" value="30"/>
            <property name="hibernate.c3p0.idle_test_period" value="60"/>
        </properties>
    </persistence-unit>

</persistence>
